{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rust-sa",
  "version": "0.1.0",
  "identifier": "com.conao3.rust-sa",
  "build": {
    "frontendDist": "dist",
    "devUrl": "https://sa.localhost",
    "beforeBuildCommand": "make -C frontend build && rm -rf src-tauri/dist && cp -r frontend/.output/public src-tauri/dist"
  },
  "app": {
    "windows": [
      {
        "title": "rust-sa",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "url": "/"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
